apiVersion: v1
kind: Secret
metadata:
  name: db-secret
  labels:
    app: db-secret
type: Opaque
stringData:
  # Database connection string (DSN)
  # Format: mariadb+pymysql://user:password@host:port/database
  # Example with Kubernetes service: mariadb+pymysql://user:password@mariadb-service.default.svc.cluster.local:3306/database
  # Example with IP: mariadb+pymysql://user:password@10.0.0.1:3306/database
  dsn: "mariadb+pymysql://user:password@mariadb-service.default.svc.cluster.local:3306/database"
